# These go in desktop/config.json (or enter them via the Settings tray menu)

# Get a FREE key from https://aistudio.google.com → Get API Key
# Used by the desktop app to classify unknown websites
GEMINI_API_KEY=AIza...

# Get from https://supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...your-anon-public-key...

# The dashboard (docs/index.html) asks for these credentials on first open
# and saves them in browser localStorage — no code changes needed.
